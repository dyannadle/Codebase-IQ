# Database
DATABASE_URL=postgresql://codebaseiq_user:codebaseiq_password@localhost:5432/codebaseiq_db

# Security (JWT)
JWT_SECRET_KEY=super_secret_jwt_key_for_local_dev_only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# GitHub OAuth
GITHUB_CLIENT_ID=your_real_github_client_id_here
GITHUB_CLIENT_SECRET=your_real_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Frontend URL for redirection
FRONTEND_URL=http://localhost:3000
