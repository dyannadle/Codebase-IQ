# Database
DATABASE_URL=postgresql://codebaseiq_user:codebaseiq_password@127.0.0.1:5433/codebaseiq_db

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0

# Security (JWT)
JWT_SECRET_KEY=super_secret_jwt_key_for_local_dev_only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=local_dev_key

# GitHub (For cloning private repos later)
GITHUB_PAT=your_github_personal_access_token_here

# Neo4j (Graph DB)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=codebaseiq_neo4j_password

# LLM Provider
OPENAI_API_KEY=your_openai_api_key_here

